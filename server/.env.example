# Configuration Template
# ----------------------
# IMPORTANT: Never commit actual .env files. Copy this file to '.env' and replace the mockup values.

# ---- Server Configuration ----
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ---- Database Setup (MySQL) ----
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=squad404
DB_PORT=3306

# ---- Security & Authentication ----
# Must be a cryptographically secure 64+ char random string
JWT_SECRET=your_ultra_secure_jwt_secret_generator
# Google OAuth Client ID for external sign-ins
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ---- Outbound Mailing System (Nodemailer) ----
EMAIL_USER=your_support_address@gmail.com
# Use an App Password if executing through Gmail/Google Workspace
EMAIL_PASS=your_16_char_app_password

# ---- Token Invalidation (Redis) ----
REDIS_URL=redis://localhost:6379
